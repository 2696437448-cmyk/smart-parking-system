{
  "id": null,
  "uid": "smart-parking-step17-fault",
  "title": "Smart Parking Step17 - Fault State",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "tags": ["smart-parking", "step17", "fault"],
  "panels": [
    {
      "type": "timeseries",
      "title": "Model Service Up (Expected 0)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {"expr": "up{job=\"model-service\"}", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Circuit Breaker Open State",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "resilience4j_circuitbreaker_state{name=\"modelServiceCb\",state=~\"open|OPEN\"}", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Gateway Request Rate (rps)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"expr": "sum(rate(http_server_requests_seconds_count{application=\"gateway-service\"}[1m]))", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Parking Error Rate (%)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {"expr": "100 * sum(rate(smart_parking_http_errors_total{service=\"parking-service\"}[1m])) / clamp_min(sum(rate(smart_parking_http_requests_total{service=\"parking-service\"}[1m])), 0.0001)", "refId": "A"}
      ]
    }
  ]
}
