# Smart Parking secure environment template
# Copy to `.env` for non-demo usage and replace every CHANGE_ME value before start.

# Gateway
UPSTREAM_TIMEOUT_MS=2500
UPSTREAM_CONNECT_TIMEOUT_MS=10000

# Parking service / compose dependencies
MYSQL_HOST_PORT=13306
MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD
MYSQL_DATABASE=smart_parking
MYSQL_USER=smart_parking_app
MYSQL_PASSWORD=CHANGE_ME_MYSQL_APP_PASSWORD
REDIS_HOST=redis
REDIS_PORT=6379
IDEMPOTENCY_TTL_SECONDS=7200
LOCK_WAIT_SECONDS=0.1
LOCK_LEASE_SECONDS=3.0
ENABLE_MQ=true
SMART_PARKING_DATA_ROOT=/workspace/data
RABBIT_API_URL=http://rabbitmq:15672/api
RABBIT_USER=smart_parking_rabbit
RABBIT_PASS=CHANGE_ME_RABBIT_PASSWORD
RABBITMQ_DEFAULT_USER=smart_parking_rabbit
RABBITMQ_DEFAULT_PASS=CHANGE_ME_RABBIT_PASSWORD
GF_ADMIN_USER=smart_parking_admin
GF_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ETL / local QA
STEP11_MYSQL_HOST=127.0.0.1
STEP11_MYSQL_PORT=13306
STEP11_MYSQL_USER=smart_parking_app
STEP11_MYSQL_PASSWORD=CHANGE_ME_MYSQL_APP_PASSWORD
STEP11_MYSQL_DATABASE=smart_parking

# Frontend runtime examples (frontend uses apps/frontend/.env.local)
VITE_GATEWAY_BASE_URL=http://localhost:8080
VITE_REALTIME_WS_URL=ws://localhost:8090/ws/status
VITE_GATEWAY_POLL_URL=http://localhost:8080/api/v1/admin/realtime/status
